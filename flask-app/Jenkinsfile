pipeline {
agent any

environment {
    IMAGE_NAME = "rakesh6nm/my-flask-app"
    TAG = "${BUILD_NUMBER}"
    GIT_REPO = "https://github.com/rakesh611/AUSTRALIA-WEATHER-RAIN-PREDICTION.git"
    GITOPS_PATH = "flask-k8s-manifests"
}

stages {

    stage('Clone Application Repo') {
        steps {
            git branch: 'main', url: "${GIT_REPO}"
        }
    }

    stage('Build Docker Image') {
        steps {
            sh '''
            echo "Current Directory:"
            pwd
            echo "Files:"
            ls -l

            docker build -t rakesh6nm/my-flask-app:${BUILD_NUMBER} -f flask-app/Dockerfile ./flask-app
            '''
        }
    }

    stage('Security Scan (Trivy)') {
        steps {
            sh '''
            trivy image --exit-code 0 --severity HIGH,CRITICAL $IMAGE_NAME:$TAG
            '''
        }
    }

    stage('Docker Login (Token Based)') {
        steps {
            withCredentials([string(credentialsId: 'dockerhub-token', variable: 'DOCKER_TOKEN')]) {
                sh '''
                echo $DOCKER_TOKEN | docker login -u rakesh6nm --password-stdin
                '''
            }
        }
    }

    stage('Push Image') {
        steps {
            sh '''
            docker push $IMAGE_NAME:$TAG
            docker tag $IMAGE_NAME:$TAG $IMAGE_NAME:latest
            docker push $IMAGE_NAME:latest
            '''
        }
    }

    stage('Update GitOps Manifest') {
        steps {
            withCredentials([usernamePassword(credentialsId: 'github-creds', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                sh '''
                # Clone same repo (GitOps folder inside it)
                git clone https://$GIT_USER:$GIT_PASS@github.com/rakesh611/AUSTRALIA-WEATHER-RAIN-PREDICTION.git

                cd AUSTRALIA-WEATHER-RAIN-PREDICTION/$GITOPS_PATH

                # Update image tag
                sed -i "s|image:.*|image: rakesh6nm/my-flask-app:$TAG|g" deployment.yaml

                # Git config
                git config user.email "jharakesh485@gmail.com"
                git config user.name "Rakesh"

                git add deployment.yaml
                git commit -m "Updated image to version $TAG"
                git push
                '''
            }
        }
    }
}

post {
    success {
        echo "✅ DevSecOps Pipeline Completed Successfully!"
    }
    failure {
        echo "❌ Pipeline Failed! Check logs."
    }
}

}
